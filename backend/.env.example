# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Database ──────────────────────────────────────────────
# Local dev (Docker):
DATABASE_URL=postgresql+asyncpg://pyramid:pyramid@db:5432/pyramid_scheme
# Supabase production — use the direct connection (port 5432), NOT the pooler.
# Format: postgresql+asyncpg://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── CORS ─────────────────────────────────────────────────
# Local dev:
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# Production (Render env var — add your Vercel frontend URL):
# CORS_ORIGINS=["https://your-app.vercel.app"]

# ── Debug / dev sim ──────────────────────────────────────
# Enables /api/dev/* simulation endpoints + Mailhog email.
# Set to false in production.
DEBUG=true

# ── Email ─────────────────────────────────────────────────
# Local dev: Mailhog catches everything (view at http://localhost:8025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pyramidscheme.gg

# Production (Resend): set these on Render instead of .env
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USER=resend
# SMTP_PASSWORD=re_YOUR_RESEND_API_KEY
# SMTP_FROM=noreply@yourdomain.com   # must be a verified Resend sender domain

# URL embedded in invite links (set to Vercel frontend URL in production)
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://your-app.vercel.app

# ── Payment QR (frontend) ────────────────────────────────
# Flat 0/1 string encoding the guest buy-in QR code matrix.
# Set this in the Render dashboard (not here — it's a frontend env var).
# Generate with: python3 scripts/gen-qr.py 'YOUR_PAYMENT_URL'
# If unset, the QR is simply hidden and the dialog still works.
# PAYMENT_QR_DATA=

# ── Stripe ───────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
