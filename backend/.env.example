# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pyramid_scheme

# ── Auth ─────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Debug / dev sim ──────────────────────────────────────
# Enables /api/dev/* simulation endpoints + Mailhog email.
# Set to false (or omit) in production.
DEBUG=true

# ── Email ─────────────────────────────────────────────────
# Dev: Mailhog catches everything (view at http://localhost:8025)
# Prod: set DEBUG=false and configure real SMTP below
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pyramidscheme.gg
FRONTEND_URL=http://localhost:5173

# ── Stripe ───────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── Email ─────────────────────────────────────────────────
# Dev mode: invite URLs are logged to the backend console (no email sent).
# Set EMAIL_DEV_MODE=false and configure SMTP_* for real email sending.
EMAIL_DEV_MODE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com

# URL embedded in invite links (change to your deployed domain in prod)
FRONTEND_URL=http://localhost:5173
