# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/pyramid_scheme

# ── Auth ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Debug / dev sim ──────────────────────────────────────
DEBUG=true

# ── Email (Mailhog in Docker — view at http://localhost:8025) ─
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pyramidscheme.gg
FRONTEND_URL=http://localhost:5173

# ── Stripe ───────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_WEBHOOK_SECRET=whsec_stub
