# Local dev environment — copy to backend/.env for use with docker compose.
# Emails are caught by Mailhog at http://localhost:8025

# ── Database (Docker Compose) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://pyramid:pyramid@db:5432/pyramid_scheme

# ── Auth ─────────────────────────────────────────────────
SECRET_KEY=local-dev-secret-not-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Debug ────────────────────────────────────────────────
DEBUG=true

# ── Email (Mailhog) ───────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pyramid-scheme.live
FRONTEND_URL=http://localhost:5173

# ── Stripe (stubbed) ─────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_WEBHOOK_SECRET=whsec_stub
