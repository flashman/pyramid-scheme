# Production environment — paste this into Render Secret Files at /app/.env
# Fill in the YOUR_* placeholders before pasting.

# ── Database (Supabase session pooler) ───────────────────
DATABASE_URL=postgresql+asyncpg://postgres.sehvxdbxiicznfodbvjo:YOUR_SUPABASE_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ── Auth ─────────────────────────────────────────────────
SECRET_KEY=YOUR_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["https://pyramid-scheme-frontend.onrender.com"]

# ── Debug ────────────────────────────────────────────────
DEBUG=false

# ── Email (Resend) ────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=resend
SMTP_PASSWORD=YOUR_RESEND_API_KEY
SMTP_FROM=YOUR_VERIFIED_SENDER@yourdomain.com
FRONTEND_URL=https://pyramid-scheme-frontend.onrender.com

# ── Stripe (stubbed) ─────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_WEBHOOK_SECRET=whsec_stub
