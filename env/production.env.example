# Production environment — paste this into Render Secret Files at /app/.env
# Fill in the YOUR_* placeholders before pasting.

# ── Database (Supabase session pooler) ───────────────────
DATABASE_URL=postgresql+asyncpg://postgres.sehvxdbxiicznfodbvjo:YOUR_SUPABASE_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ── Auth ─────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["https://pyramid-scheme.live"]

# ── Debug ────────────────────────────────────────────────
DEBUG=false

# ── Email (Resend) ────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=resend
SMTP_PASSWORD=YOUR_RESEND_API_KEY
SMTP_FROM=pigeon@pyramid-scheme.live
FRONTEND_URL=https://pyramid-scheme.live

# ── Stripe (stubbed) ─────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_WEBHOOK_SECRET=whsec_stub

# ── Frontend env vars (set in Render dashboard for the static site service) ──
# NOT backend vars — do not paste here.
#
# PAYMENT_QR_DATA — flat 0/1 string encoding the guest buy-in QR matrix.
# Generate: python3 scripts/gen-qr.py 'YOUR_PAYMENT_URL'
# If unset the QR is hidden; the dialog still works.
